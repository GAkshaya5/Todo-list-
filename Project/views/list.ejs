<!DOCTYPE html>
<html>
    <head>
        <title>Todo list</title>
        <link rel="stylesheet" href="css/style.css">
    </head>
    <body>
        <div class="box">
            <h1>Todo List</h1>
        </div>
        <div class="box">
           <% for(var i= 0; i< ejes.length; i++){ %>
            <input type="checkbox">
                <p><%= ejes[i] %></p>
            }

        <form action="/" method="post">
            <input type="text" name="ele1" placeholder="enter the new task">
            <button type="submit">+</button>
        </div>
    </body>
</html>